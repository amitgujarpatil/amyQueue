# AmyQueue Configuration Example
# Copy this file to .env and update with your values

# Node Configuration
NODE_ID=controller-1
NODE_ROLE=controller  # controller or broker
HTTP_PORT=8080
GRPC_PORT=8082
RAFT_PORT=8081

# Data Directories
DATA_DIR=./data
LOG_DIR=./logs

# Cluster Configuration
CLUSTER_ID=amyqueue-cluster-1
CONTROLLER_PEERS=controller-1:8081,controller-2:8081,controller-3:8081

# Broker Configuration (if NODE_ROLE=broker)
BROKER_ID=broker-1
BROKER_HOST=localhost
BROKER_PORT=9092

# Raft Configuration
RAFT_ELECTION_TIMEOUT_MS=1000
RAFT_HEARTBEAT_INTERVAL_MS=100
RAFT_SNAPSHOT_INTERVAL=10000

# Topic Defaults
DEFAULT_REPLICATION_FACTOR=3
DEFAULT_PARTITIONS=10
DEFAULT_RETENTION_MS=604800000  # 7 days
DEFAULT_SEGMENT_BYTES=1073741824  # 1GB

# Consumer Group Defaults
SESSION_TIMEOUT_MS=30000
HEARTBEAT_INTERVAL_MS=3000

# Performance Tuning
NUM_NETWORK_THREADS=3
NUM_IO_THREADS=8
SOCKET_SEND_BUFFER_BYTES=102400
SOCKET_RECEIVE_BUFFER_BYTES=102400
MAX_MESSAGE_BYTES=1048576  # 1MB

# Logging
LOG_LEVEL=info  # debug, info, warn, error
LOG_FORMAT=json  # json or text

# Monitoring (optional)
METRICS_PORT=9090
ENABLE_METRICS=true
